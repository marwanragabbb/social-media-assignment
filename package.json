{
  "name": "social-media-auth-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Social media app authentication backend with Node.js, Express, MongoDB, Redis, and TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "nodemailer": "^6.9.5",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "redis": "^5.12.1",
    "google-auth-library": "^10.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.19",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.8",
    "@types/passport": "^1.0.9",
    "@types/passport-google-oauth20": "^2.0.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
